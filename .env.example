# Absolute path to your Claude Code data folder on the HOST machine.
# This gets mounted (read-only) into the container.
#
# macOS / Linux:
#   CLAUDE_DIR_HOST=/Users/you/.claude
#   CLAUDE_DIR_HOST=/home/you/.claude
#
# Windows (Docker Desktop) — use forward slashes:
#   CLAUDE_DIR_HOST=C:/Users/you/.claude
CLAUDE_DIR_HOST=C:/Users/you/.claude
